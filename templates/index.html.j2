<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8">
  <title>Launchpad new bugs for {{ project }} project</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="description" content="Monitoring dashboard for new bugs submitted in the {{ project }} project on Launchpad.">
  <link rel="icon" type="image/svg+xml" href="favicon.svg">
  <link rel="stylesheet" href="pico.min.css">
  <style>
    :root {
      --pico-background-color: #FFDD91;
      --pico-card-background-color: #91FFDD;
    }

    html {
      background-color: var(--pico-background-color);
    }

    main {
      max-width: 800px;
      margin: 2rem auto;
      text-align: center;
    }

    img {
      width: 100%;
      height: auto;
      border: 1px solid #ccc;
      background: var(--pico-card-background-color);
      padding: 0.5rem;
    }

    .calendar_container {
      display: flex;
      align-items: center; /* Aligns icon and text vertically */
      gap: 0.5em;
      justify-content: center; /* Optional: centers the group */
    }

    .calendar {
      width: 34px;
      height: 34px;
      background-image: url('svg/calendar.svg');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      position: relative;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      margin-bottom: 50px;
    }

    .date {
      font-size: 0.7em;
      text-align: center;
      color: #000000;
      margin-bottom: 1px;
    }

    .month {
      margin-top: 1px;
      text-align: center;
      font-size: 0.3em;
      color: #FFFFFF;
    }

    tr.current-week td {
      background-color: #F9EEFF !important;
    }

    .legend-box {
      display: inline-block;
      width: 1em;
      height: 1em;
      background-color: #F9EEFF;
      border: 1px solid #fff;
      margin-right: 0.5em;
      vertical-align: middle;
    }

    .legend-text {
      font-size: 0.9em;
      color: #333;
    }
  </style>

</head>
<body>
  <main>
    <h1>🪲 Launchpad new bugs for {{ project }} project</h1>
    <p>Monitoring status for new bugs submitted in <code>{{ project }}</code>.</p>

    <div class="calendar_container">
      <div class="calendar">
        <div class="month" id="month">---</div>
        <div class="date" id="date">--</div>
      </div>
      <h2 style="padding-bottom: 34px;">Bug Trends</h2>
    </div>
    <p>Current open bugs: <strong>{{ count }}</strong></p>

    <details class="dropdown">
      <summary role="button">1 Month</summary>
      <ul>
        {% for p in periods %}
        <li><a href="#" data-period="{{ p.key }}">{{ p.label }}</a></li>
        {% endfor %}
      </ul>
    </details>

    {% for p in periods %}
    <div class="period-graphs" id="graphs-{{ p.key }}" style="{% if p.key != '30d' %}display:none{% endif %}">
      <img src="bugs_new_{{ p.key }}.png" alt="New Bugs Graph ({{ p.label }})" width="897" height="368"{% if p.key == '30d' %} fetchpriority="high"{% endif %}>
      <h3 style="margin-top: 2rem;">📊 Daily Change</h3>
      <img src="bugs_delta_{{ p.key }}.png" alt="Daily Bug Count Change ({{ p.label }})" width="897" height="268">
    </div>
    {% endfor %}

    <h2>📝 Latest New Bugs</h2>
    <table role="grid">
      <thead>
        <tr>
          <th>ID</th>
          <th>Title</th>
          <th>Date</th>
          <th>Heat</th>
        </tr>
      </thead>
      <tbody>
        {% for bug in latest_bugs %}
        <tr{% if bug.is_current_week %} class="current-week"{% endif %}>
          <td><a href="{{ bug.link }}" target="_blank">#{{ bug.id }}</a></td>
          <td>{{ bug.title }}</td>
          <td>{{ bug.date }}</td>
          <td>{{ bug.heat }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    <p class="legend-text">
      <span class="legend-box"></span>
      Bugs reported less than 1 week ago
    </p>

    <h2>🔥 Hottest New Bugs</h2>
    <table role="grid">
      <thead>
        <tr>
          <th>ID</th>
          <th>Title</th>
          <th>Date</th>
          <th>Heat</th>
        </tr>
      </thead>
      <tbody>
        {% for bug in hottest_bugs %}
        <tr{% if bug.is_current_week %} class="current-week"{% endif %}>
          <td><a href="{{ bug.link }}" target="_blank">#{{ bug.id }}</a></td>
          <td>{{ bug.title }}</td>
          <td>{{ bug.date }}</td>
          <td>{{ bug.heat }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    <p class="legend-text">
      <span class="legend-box"></span>
      Bugs reported less than 1 week ago
    </p>

    <footer>
      <small>Made with ❤️ by Uggla - Charts generated with <code>rrdtool</code> — Styled by <a href="https://picocss.com/" target="_blank">Pico.css</a></small>
    </footer>
  </main>


  <script>
    const now = new Date();
    document.getElementById('date').textContent = String(now.getDate()).padStart(2, '0');
    document.getElementById('month').textContent = now.toLocaleString('default', { month: 'short' });

    // Period dropdown toggle
    document.querySelectorAll("[data-period]").forEach(link => {
      link.addEventListener("click", (e) => {
        e.preventDefault();
        const period = link.dataset.period;
        document.querySelectorAll(".period-graphs").forEach(g => g.style.display = "none");
        document.getElementById("graphs-" + period).style.display = "block";
        const dropdown = link.closest("details");
        dropdown.querySelector("summary").textContent = link.textContent;
        dropdown.removeAttribute("open");
      });
    });

  </script>
</body>
</html>
